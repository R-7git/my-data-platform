create or replace transient table RAW_LAKE.ANALYTICS.stg_customers
         as
        (-- This is a "Staging" model (Silver Layer)
-- It cleans the raw data from the Landing Zone

WITH raw_source AS (
    -- 1. Import the Raw Data using the Source we just defined
    -- syntax: source('source_name', 'table_name')
    SELECT * 
    FROM RAW_LAKE.LANDING.customers
),

cleaned AS (
    -- 2. Apply Transformations
    SELECT
        customer_id,
        
        -- Fix Names: "john" -> "John"
        INITCAP(first_name) as first_name,
        INITCAP(last_name) as last_name,
        
        -- Fix Email: "User@Example.COM" -> "user@example.com"
        LOWER(email) as email,
        
        -- Standardize States (Example Logic)
        CASE 
            WHEN LENGTH(state) > 2 THEN 'XX' -- Flag bad data
            ELSE UPPER(state)                -- Ensure 'ny' becomes 'NY'
        END as state,
        
        -- Fix Date: Cast string to real Date object
        TO_DATE(signup_date) as signup_date

    FROM raw_source
)

SELECT * FROM cleaned
        );
